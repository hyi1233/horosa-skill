{
  "mcpServers": {
    "horosa": {
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "<ABSOLUTE_PATH_TO_REPO>/horosa-skill",
        "horosa-skill",
        "serve",
        "--transport",
        "stdio"
      ],
      "cwd": "<ABSOLUTE_PATH_TO_REPO>/horosa-skill"
    }
  }
}
